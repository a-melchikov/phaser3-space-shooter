    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "firebase-admin": "^13.2.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "prisma": "^6.6.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
